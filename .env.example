# === Generate Tool (Anime Card Generator) ===
GEMINI_ANALYZE_API_KEY=
GEMINI_ANALYZE_BASE_URL=https://yunwu.ai
GEMINI_ANALYZE_MODEL=gemini-3.1-flash-lite-preview

# === Image Generation (Generate + Watermark tools) ===
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_BASE_URL=https://yunwu.ai
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# === Watermark Tool ===
GROK_API_KEY=
GROK_BASE_URL=https://yunwu.ai/v1
GROK_MODEL=grok-4.2-image

DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://yunwu.ai/v1

# === Refer2Result Tool ===
REFER_BASE_URL=https://yunwu.ai/v1
REFER_IMAGE_API_KEY=
REFER_RECOGNIZE_API_KEY=
REFER_MODEL=gemini-3-pro-image-preview
REFER_RECOGNIZE_MODEL=gemini-3.1-flash-lite-preview

# === Frontend Runtime Config ===
FRONTEND_GENERATE_API_PATH=/api/generate
FRONTEND_REFER_API_PATH=/api/refer
FRONTEND_WATERMARK_API_PATH=/api/watermark

# === Server ===
PORT=8000
HOST=0.0.0.0